{
  "name": "a2a-slackbot",
  "version": "1.0.0",
  "description": "A Slack bot powered by the A2A protocol",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start": "node ./dist/index.js",
    "lint": "npx @biomejs/biome check src",
    "lint:fix": "npx @biomejs/biome check --write src",
    "test": "node --import tsx --test 'src/**/*.test.ts'"
  },
  "author": "dudo-home-lab",
  "license": "MIT",
  "keywords": [
    "slack",
    "bolt",
    "a2a",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dudo-home-lab/a2a-slackbot.git"
  },
  "bugs": {
    "url": "https://github.com/dudo-home-lab/a2a-slackbot/issues"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.10",
    "@ai-sdk/anthropic": "^3.0.64",
    "@slack/bolt": "^4.6.0",
    "ai": "^6.0.105",
    "uuid": "^11.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@slack/types": "^2.20.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
